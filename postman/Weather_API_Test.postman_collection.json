    {
      "name": "天气预报（7天）接口",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 预报天数设置为全局变量（7天）\r",
              "pm.globals.set(\"days\", \"7d\");\r",
              "// 获取全局变量\r",
              "const days = pm.globals.get(\"days\");\r",
              "console.log(days); // 输出: 7d"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://nj65np8ukv.re.qweatherapi.com/v7/weather/{{days}}?location=北京&key=a19b5082a277449186531343580ae182",
          "protocol": "https",
          "host": [
            "nj65np8ukv",
            "re",
            "qweatherapi",
            "com"
          ],
          "path": [
            "v7",
            "weather",
            "{{days}}"
          ],
          "query": [
            {
              "key": "days",
              "value": "7d",
              "disabled": true
            },
            {
              "key": "location",
              "value": "北京",
              "description": "位置"
            },
            {
              "key": "key",
              "value": "a19b5082a277449186531343580ae182",
              "description": "api key"
            }
          ]
        }
      },
      "response": []
    }
